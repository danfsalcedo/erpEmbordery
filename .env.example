# Copia este archivo a .env y ajusta los valores.
# .env está en .gitignore y nunca se versiona.

# ===== Base de datos =====
POSTGRES_USER=erp
POSTGRES_PASSWORD=erp_dev_password
POSTGRES_DB=erp_bordados
# El host 'db' es el nombre del servicio en docker-compose
DATABASE_URL=postgresql+psycopg://erp:erp_dev_password@db:5432/erp_bordados

# ===== Seguridad / JWT =====
# Genera uno propio para producción: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-secret-change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14

# ===== Multi-tenant =====
# single = una empresa por instancia | shared = varios tenants en una instancia
TENANT_MODE=single

# ===== Seed del tenant/usuario inicial (solo desarrollo) =====
SEED_TENANT_NAME=Bordados Familia
SEED_OWNER_USERNAME=dueno
SEED_OWNER_PASSWORD=cambiar123
